# ============================================================
# frontend/.env.example
# Copy this file to .env and fill in your own values.
# NEVER commit the actual .env file to version control.
# Add .env to your .gitignore file.
#
# IMPORTANT — Vite environment variable rules:
#   1. All variables MUST be prefixed with VITE_ to be
#      accessible inside your React code.
#   2. Access them in code via: import.meta.env.VITE_*
#   3. Variables WITHOUT the VITE_ prefix are ignored by Vite
#      and will be undefined in the browser.
#   4. After changing this file, restart the Vite dev server.
# ============================================================


# ── Backend API URL ──────────────────────────────────────────
# The base URL of your Express backend server.
# Used by the Axios instance in src/api/axios.js as the
# baseURL for all API requests.
#
# Development (default — Express runs on port 5000):
VITE_API_URL=http://localhost:5000

# Production — replace with your deployed backend URL:
# VITE_API_URL=https://your-backend-domain.com


# ── App Name (optional) ──────────────────────────────────────
# Displayed in the browser tab title and anywhere you use
# import.meta.env.VITE_APP_NAME in the UI.
VITE_APP_NAME=Sniply